---
import { socialLinks } from '../data/dashboards.js';
---

<section id="contacto" class="contacto section">
  <div class="container">
    <div class="contacto-grid">
      <div class="contacto-info reveal">
        <span class="contacto-label mono">CONTACTO</span>
        <h2 class="contacto-title">¿Trabajamos juntos?</h2>
        <p class="contacto-text">
          Estoy disponible para proyectos de desarrollo de dashboards, componentes reutilizables y arquitecturas frontend.
        </p>

        <div class="contacto-links">
          <a href={socialLinks.github} target="_blank" rel="noopener" class="contacto-link github">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            <span>GitHub</span>
          </a>
          <a href={socialLinks.linkedin} target="_blank" rel="noopener" class="contacto-link">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            <span>LinkedIn</span>
          </a>
          <a href={`mailto:${socialLinks.email}`} class="contacto-link">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
            <span>Email</span>
          </a>
        </div>
      </div>

      <form class="contacto-form reveal" onsubmit="event.preventDefault(); alert('Mensaje enviado correctamente');">
        <div class="form-group">
          <label for="name" class="form-label mono">Nombre</label>
          <input type="text" id="name" name="name" placeholder="Tu nombre" required />
        </div>

        <div class="form-group">
          <label for="email" class="form-label mono">Correo</label>
          <input type="email" id="email" name="email" placeholder="tu@email.com" required />
        </div>

        <div class="form-group">
          <label for="project" class="form-label mono">Proyecto</label>
          <input type="text" id="project" name="project" placeholder="Tipo de proyecto" />
        </div>

        <div class="form-group">
          <label for="message" class="form-label mono">Mensaje</label>
          <textarea id="message" name="message" rows="5" placeholder="Describe tu proyecto o consulta..." required></textarea>
        </div>

        <button type="submit" class="btn btn-primary form-submit">
          ENVIAR MENSAJE
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  .contacto {
    background-color: var(--bg-primary);
  }

  .contacto-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
  }

  .contacto-label {
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.15em;
    display: block;
    margin-bottom: 24px;
  }

  .contacto-title {
    font-size: 52px;
    color: var(--text-primary);
    margin-bottom: 16px;
  }

  .contacto-text {
    font-size: 18px;
    color: var(--text-secondary);
    margin-bottom: 40px;
    max-width: 400px;
  }

  .contacto-links {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .contacto-link {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 16px;
    color: var(--text-secondary);
    transition: color 0.15s ease;
  }

  .contacto-link:hover {
    color: var(--text-primary);
  }

  .contacto-link.github:hover svg {
    color: #FFFFFF;
  }

  .contacto-form {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius);
    padding: 40px;
  }

  .form-group {
    margin-bottom: 20px;
  }

  .form-label {
    display: block;
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 8px;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 14px 16px;
    background-color: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 16px;
    transition: border-color 0.15s ease;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--accent-blue);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--text-muted);
  }

  .form-submit {
    width: 100%;
    padding: 16px;
    margin-top: 8px;
  }

  @media (max-width: 768px) {
    .contacto-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .contacto-title {
      font-size: 36px;
    }

    .contacto-form {
      padding: 24px;
    }
  }
</style>