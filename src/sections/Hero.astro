---

<section id="inicio" class="hero">
  <div class="hero-container container">
    <div class="hero-content">
      <div class="hero-label reveal">
        <span class="mono">OPEN SOURCE DASHBOARD COLLECTION</span>
      </div>

      <h1 class="hero-title reveal">
        <span class="line line-1">Dashboards</span>
        <span class="line line-2">construidos</span>
        <span class="line line-3">para producción.</span>
      </h1>

      <p class="hero-description reveal">
        Soy Orlando Tellez. Desarrollo plantillas administrativas modernas, escalables y de código abierto enfocadas en arquitectura limpia, experiencia profesional y rendimiento real.
      </p>

      <div class="hero-cta reveal">
        <a href="#dashboards" class="btn btn-primary">
          EXPLORAR DASHBOARDS →
        </a>
        <a href="https://github.com/orlandotellez" target="_blank" rel="noopener" class="btn btn-outline">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          GITHUB
        </a>
      </div>
    </div>

    <div class="hero-preview reveal">
      <div class="preview-frame">
        <div class="preview-image">
          <div class="preview-placeholder">
            <div class="preview-header">
              <div class="preview-dots">
                <span></span><span></span><span></span>
              </div>
              <div class="preview-title mono">analytics-pro-dashboard</div>
            </div>
            <div class="preview-content">
              <div class="preview-sidebar">
                <div class="preview-nav-item"></div>
                <div class="preview-nav-item"></div>
                <div class="preview-nav-item"></div>
                <div class="preview-nav-item"></div>
              </div>
              <div class="preview-main">
                <div class="preview-chart"></div>
                <div class="preview-stats">
                  <div class="preview-stat"></div>
                  <div class="preview-stat"></div>
                  <div class="preview-stat"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="preview-meta">
          <span class="mono">OPEN SOURCE</span>
          <span class="mono">ACTUALIZADO 2026</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: calc(var(--nav-height) + 120px);
    padding-bottom: var(--section-padding);
    background-color: var(--bg-primary);
    display: flex;
    align-items: center;
  }

  .hero-container {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: 48px;
    align-items: center;
  }

  .hero-label {
    margin-bottom: 24px;
  }

  .hero-label span {
    color: var(--accent-blue);
    font-size: 11px;
    letter-spacing: 0.1em;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: 92px;
    font-weight: 700;
    line-height: 0.95;
    margin-bottom: 32px;
  }

  .hero-title .line {
    display: block;
  }

  .hero-title .line-1,
  .hero-title .line-2 {
    color: var(--text-primary);
  }

  .hero-title .line-3 {
    color: var(--accent-blue);
  }

  .hero-description {
    font-size: 18px;
    line-height: 1.7;
    max-width: 560px;
    margin-bottom: 40px;
  }

  .hero-cta {
    display: flex;
    gap: 16px;
  }

  .hero-preview {
    position: relative;
  }

  .preview-frame {
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius);
    overflow: hidden;
    transition: transform 0.15s ease;
  }

  .preview-frame:hover {
    transform: translateY(-4px);
  }

  .preview-image {
    aspect-ratio: 16/10;
    background-color: var(--bg-secondary);
  }

  .preview-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .preview-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border-color);
  }

  .preview-dots {
    display: flex;
    gap: 6px;
  }

  .preview-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--border-color);
  }

  .preview-dots span:first-child {
    background-color: #EF4444;
  }

  .preview-dots span:nth-child(2) {
    background-color: #F59E0B;
  }

  .preview-dots span:nth-child(3) {
    background-color: #22C55E;
  }

  .preview-title {
    font-size: 11px;
    color: var(--text-muted);
  }

  .preview-content {
    display: flex;
    height: calc(100% - 45px);
  }

  .preview-sidebar {
    width: 60px;
    border-right: 1px solid var(--border-color);
    padding: 16px 8px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .preview-nav-item {
    height: 24px;
    background-color: var(--bg-elevated);
    border-radius: 2px;
  }

  .preview-main {
    flex: 1;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .preview-chart {
    flex: 1;
    background: linear-gradient(180deg, var(--bg-elevated) 0%, transparent 100%);
    border-radius: 2px;
    position: relative;
  }

  .preview-chart::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60%;
    background: linear-gradient(90deg, var(--accent-blue) 0%, transparent 100%);
    opacity: 0.3;
  }

  .preview-stats {
    display: flex;
    gap: 12px;
  }

  .preview-stat {
    flex: 1;
    height: 48px;
    background-color: var(--bg-elevated);
    border-radius: 2px;
  }

  .preview-meta {
    display: flex;
    justify-content: space-between;
    padding: 16px 0;
    font-size: 10px;
    color: var(--text-muted);
  }

  @media (max-width: 1024px) {
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-title {
      font-size: 64px;
    }

    .hero-description {
      margin: 0 auto 40px;
    }

    .hero-cta {
      justify-content: center;
    }

    .hero-preview {
      max-width: 600px;
      margin: 0 auto;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: calc(var(--nav-height) + 80px);
    }

    .hero-title {
      font-size: 48px;
    }

    .hero-description {
      font-size: 16px;
    }

    .hero-cta {
      flex-direction: column;
    }
  }
</style>
