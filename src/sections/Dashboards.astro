---
import { dashboards, categories } from '../data/dashboards.js';
---

<section id="dashboards" class="dashboards section">
  <div class="container">
    <div class="dashboards-header reveal">
      <div class="header-left">
        <span class="header-label mono">DASHBOARDS</span>
        <h2 class="header-title">Plantillas desarrolladas.</h2>
      </div>

      <div class="header-filters">
        {categories.map(cat => (
          <button
            class="filter-btn mono"
            data-category={cat.id}
          >
            {cat.label}
          </button>
        ))}
      </div>
    </div>

    <div class="dashboards-grid">
      {dashboards.map((dashboard, index) => (
        <article
          class="dashboard-card card reveal"
          data-category={dashboard.category}
          style={`--delay: ${index * 0.05}s`}
        >
          <div class="card-preview">
            <div class="preview-placeholder">
              <div class="preview-ui">
                <div class="ui-header"></div>
                <div class="ui-body">
                  <div class="ui-chart"></div>
                  <div class="ui-rows">
                    <div class="ui-row"></div>
                    <div class="ui-row"></div>
                    <div class="ui-row"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="card-body">
            <span class="card-id mono">{dashboard.id}</span>
            <h3 class="card-title">{dashboard.name}</h3>
            <p class="card-description">{dashboard.description}</p>

            <div class="card-tags">
              {dashboard.stack.slice(0, 4).map(tech => (
                <span class="tag">{tech}</span>
              ))}
            </div>

            <div class="card-footer">
              <a
                href={dashboard.githubUrl}
                target="_blank"
                rel="noopener"
                class="card-github"
                aria-label="Ver en GitHub"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                </svg>
              </a>
              <a href={`/dashboard/${dashboard.slug}`} class="card-link">
                VER DASHBOARD →
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .dashboards {
    background-color: var(--bg-primary);
  }

  .dashboards-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 64px;
    gap: 32px;
  }

  .header-label {
    font-size: 10px;
    color: var(--accent-blue);
    letter-spacing: 0.15em;
    display: block;
    margin-bottom: 12px;
  }

  .header-title {
    font-size: 52px;
    color: var(--text-primary);
  }

  .header-filters {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 8px 16px;
    background: none;
    border: none;
    font-size: 11px;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.15s ease;
    position: relative;
  }

  .filter-btn:hover {
    color: var(--text-secondary);
  }

  .filter-btn.active {
    color: var(--text-primary);
  }

  .filter-btn.active::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 8px;
    right: 8px;
    height: 2px;
    background-color: var(--accent-blue);
  }

  .dashboards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--gutter);
  }

  .dashboard-card {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius);
    overflow: hidden;
    transition: transform 0.15s ease;
  }

  .dashboard-card:hover {
    transform: translateY(-4px);
  }

  .dashboard-card.hidden {
    display: none;
  }

  .card-preview {
    height: 240px;
    overflow: hidden;
    background-color: var(--bg-elevated);
    border-bottom: 1px solid var(--border-color);
  }

  .preview-placeholder {
    width: 100%;
    height: 100%;
    padding: 16px;
  }

  .preview-ui {
    width: 100%;
    height: 100%;
    background-color: var(--bg-secondary);
    border-radius: 2px;
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .dashboard-card:hover .preview-ui {
    transform: scale(1.02);
  }

  .ui-header {
    height: 32px;
    background-color: var(--bg-nav);
    border-bottom: 1px solid var(--border-color);
  }

  .ui-body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    height: calc(100% - 32px);
  }

  .ui-chart {
    height: 60%;
    background: linear-gradient(180deg, var(--bg-elevated) 0%, transparent 100%);
    border-radius: 2px;
    position: relative;
  }

  .ui-chart::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(90deg, var(--accent-blue) 0%, transparent 50%);
    opacity: 0.4;
  }

  .ui-rows {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ui-row {
    height: 12px;
    background-color: var(--bg-elevated);
    border-radius: 2px;
  }

  .card-body {
    padding: 24px;
  }

  .card-id {
    font-size: 11px;
    color: var(--accent-blue);
    display: block;
    margin-bottom: 8px;
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .card-description {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card-github {
    color: var(--text-muted);
    transition: color 0.15s ease;
  }

  .card-github:hover {
    color: #FFFFFF;
  }

  .card-link {
    font-size: 13px;
    color: var(--text-secondary);
    transition: color 0.15s ease;
  }

  .card-link:hover {
    color: var(--accent-blue);
  }

  @media (max-width: 1024px) {
    .dashboards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .dashboards-header {
      flex-direction: column;
    }

    .header-title {
      font-size: 36px;
    }

    .header-filters {
      width: 100%;
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 8px;
    }

    .filter-btn {
      white-space: nowrap;
    }

    .dashboards-grid {
      grid-template-columns: 1fr;
    }

    .card-preview {
      height: 200px;
    }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.dashboard-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const category = btn.dataset.category;

      cards.forEach(card => {
        if (category === 'todos' || card.dataset.category === category) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });

  // Set first button as active
  filterBtns[0]?.classList.add('active');
</script>