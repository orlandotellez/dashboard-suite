---
const stats = [
  { number: '12+', label: 'DASHBOARDS' },
  { number: '100%', label: 'OPEN SOURCE' },
  { number: 'React', label: 'STACK BASE' },
  { number: 'GitHub', label: 'PUBLIC REPOS' }
];
---

<section class="stats section-alt">
  <div class="container">
    <div class="stats-grid">
      {stats.map((stat, index) => (
        <div class="stat-item reveal" style={`--delay: ${index * 0.1}s`}>
          <span class="stat-number">{stat.number}</span>
          <span class="stat-label mono">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats {
    padding: 48px 0;
    background-color: var(--bg-nav);
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--gutter);
  }

  .stat-item {
    text-align: center;
    padding: 24px;
  }

  .stat-number {
    display: block;
    font-family: var(--font-heading);
    font-size: 64px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .stat-number::before {
    content: '';
  }

  .stat-item:nth-child(1) .stat-number::before { color: var(--accent-blue); content: ''; }
  .stat-item:nth-child(2) .stat-number::before { color: var(--success); content: ''; }
  .stat-item:nth-child(3) .stat-number::before { color: var(--text-primary); content: ''; }
  .stat-item:nth-child(4) .stat-number::before { color: var(--text-secondary); content: ''; }

  .stat-label {
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .stat-number {
      font-size: 48px;
    }
  }
</style>